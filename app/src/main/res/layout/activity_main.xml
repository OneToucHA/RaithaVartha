<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B5E20">

    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="🌾 ರೈತ ವಾರ್ತಾ"
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="16dp"
        android:background="#2E7D32"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvDateTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Loading..."
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="16sp"
        android:padding="8dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvHeader"
        app:layout_constraintStart_toStartOf="parent"/>

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleLanguage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:singleSelection="true"
        app:layout_constraintTop_toBottomOf="@id/tvDateTime"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnKannada"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="ಕನ್ನಡ"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnEnglish"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="English"
            android:textColor="#FFFFFF"/>
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <HorizontalScrollView
        android:id="@+id/scrollChips"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/toggleLanguage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.chip.ChipGroup
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ಎಲ್ಲಾ / All"
                android:checkable="true"
                android:checked="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPaddy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌾 ಭತ್ತ"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAreca"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌴 ಅಡಿಕೆ"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCoconut"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥥 ತೆಂಗು"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTomato"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍅 ಟೊಮ್ಯಾಟೊ"/>
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="12dp"
        app:layout_constraintTop_toBottomOf="@id/scrollChips"
        app:layout_constraintBottom_toTopOf="@id/tvVoiceResult"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <TextView
        android:id="@+id/tvVoiceResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Voice Command"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toTopOf="@id/btnVoice"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnVoice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎤 Speak"
        android:textColor="#FFFFFF"
        android:backgroundTint="#388E3C"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toTopOf="@id/fabWelcome"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_dialog_info"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>